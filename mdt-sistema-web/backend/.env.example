# Puerto del servidor
PORT=5000

# ============================================
# CONFIGURACIÓN PARA HOSTINGS SEPARADOS
# ============================================

# API del Bot de Discord (IMPORTANTE)
# Si el bot está en otro hosting, usa la URL completa
# Ejemplo: https://bot.tudominio.com
BOT_API_URL=http://localhost:3000
BOT_API_KEY=HSRP_API_KEY_2026_CAMBIAR_EN_PRODUCCION_12345

# ============================================
# CONFIGURACIÓN LOCAL (MISMO SERVIDOR)
# ============================================

# Base de datos (solo si bot y MDT están en el mismo servidor)
# Comentar si usas hostings separados
DATABASE_PATH=../../policedb.db

# ============================================
# JWT Y AUTENTICACIÓN
# ============================================

# JWT Secret (CAMBIAR EN PRODUCCIÓN - usar un string aleatorio largo)
JWT_SECRET=tu_secreto_super_seguro_cambiar_en_produccion_12345_HSRP_MDT

# JWT Expiration
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# ============================================
# CORS Y SEGURIDAD
# ============================================

# CORS Origin (frontend URL)
CORS_ORIGIN=http://localhost:5173

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ============================================
# OTROS
# ============================================

# Logs
LOG_LEVEL=info

# Discord Webhook (opcional para notificaciones)
# Crear webhook en Discord: Server Settings > Integrations > Webhooks
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/TU_WEBHOOK_ID/TU_WEBHOOK_TOKEN

# Entorno
NODE_ENV=development
